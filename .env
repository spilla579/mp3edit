# MP3 Filter Tool Configuration

# Server Port
PORT=3000

# Environment
NODE_ENV=development

# File Upload Settings
MAX_FILE_SIZE=52428800

# Audio Processing
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=2

# Paths (relative to project root)
UPLOAD_DIR=uploads
OUTPUT_DIR=output
TEMP_DIR=temp
